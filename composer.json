{
    "name": "ortic/telemetry-client",
    "description": "Laravel package to send error telemetry data to an Ortic telemetry server",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Ortic",
            "email": "info@ortic.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^8.0|^9.0|^10.0|^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Ortic\\TelemetryClient\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ortic\\TelemetryClient\\TelemetryServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}